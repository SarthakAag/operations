
# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME="AI-Driven Application Support & Operations"
APP_VERSION="1.0.0"
DEBUG=True

# ── Database ──────────────────────────────────────────────────────────────────

# Production: uncomment and fill PostgreSQL URL
DATABASE_URL=postgresql://postgres:Sart2012%40@localhost:5432/ai_opd

# ── ML Model Paths ────────────────────────────────────────────────────────────
TICKET_MODEL_PATH="models/ticket_model.pkl"
ANOMALY_MODEL_PATH="models/anomaly_model.pkl"
TICKETS_CSV_PATH="data/tickets.csv"
LOGS_JSON_PATH="data/logs.json"

# ── Governance ────────────────────────────────────────────────────────────────
AUTO_RESOLVE_CONFIDENCE=0.80
HIGH_RISK_THRESHOLD=0.70
VIP_AUTO_RESOLVE=False

# ── SLA (minutes) ─────────────────────────────────────────────────────────────
SLA_P1_MINUTES=60
SLA_P2_MINUTES=240
SLA_P3_MINUTES=1440
SLA_P4_MINUTES=4320

# ── Anomaly Detection ─────────────────────────────────────────────────────────
ANOMALY_CONTAMINATION=0.10

# ── Continuous Learning ───────────────────────────────────────────────────────
RETRAIN_AFTER_N_RESOLUTIONS=50

# ── External Integrations (optional) ─────────────────────────────────────────
SERVICENOW_URL=""
JIRA_URL=""
SLACK_WEBHOOK_URL=""